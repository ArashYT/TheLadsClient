<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="TheLadsLauncher.Views.SkinManagerView">

    <UserControl.Styles>
        <!-- Action Button -->
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#1A1A2E" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="#AAAAAA" />
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="#252545" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Danger Button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#331111" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="#FF6666" />
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#441111" />
            <Setter Property="Foreground" Value="#FF4444" />
        </Style>

        <!-- Launch Button -->
        <Style Selector="Button.launch">
            <Setter Property="Background" Value="#8B0000" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Button.launch:pointerover">
            <Setter Property="Background" Value="#B00000" />
        </Style>
        <Style Selector="Button.launch:pressed">
            <Setter Property="Background" Value="#600000" />
        </Style>
    </UserControl.Styles>

    <Border Background="#0E0E18" CornerRadius="12" Padding="20" BorderBrush="#1A1A2E" BorderThickness="1">
        <ScrollViewer>
            <StackPanel Spacing="16">
                <TextBlock Text="Skin &amp; Cape Customizer" Foreground="White" FontSize="18" FontWeight="Bold"/>
                
                <!-- Player Skin Preview & Preset Selector -->
                <Grid ColumnDefinitions="*,*">
                    <!-- Skin Preview -->
                    <Border Grid.Column="0" Background="#08080C" CornerRadius="8" Height="220" BorderBrush="#1A1A2E" BorderThickness="1" Padding="12">
                        <Grid RowDefinitions="*,Auto">
                            <Image x:Name="PlayerSkinPreview" Height="160" Width="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" x:Name="SelectedAccountText" Text="No Account Selected" Foreground="#888888" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>
                    
                    <!-- Presets & Management -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8">
                        <TextBlock Text="SKIN PRESETS" Foreground="#8B0000" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                        <ComboBox x:Name="PresetSelector" HorizontalAlignment="Stretch" Height="32"/>
                        <Button Classes="action" Content="Apply Preset" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="32" Click="ApplyPreset_Click"/>
                        <Button Classes="action" Content="Save as Preset" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="32" Click="SavePreset_Click"/>
                        <Button Classes="danger" Content="Delete Preset" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="32" Click="DeletePreset_Click"/>
                        <Border Height="1" Background="#1A1A2E" Margin="0,4"/>
                        <Button Classes="action" Content="Upload local Skin (.png)" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="32" Click="UploadSkin_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Editors Toggle & Editor Canvas -->
                <Border Height="1" Background="#1A1A2E"/>
                <Grid ColumnDefinitions="*,*">
                    <Button x:Name="ToggleSkinEditorBtn" Classes="action" Content="🎨 Skin Editor" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="ToggleSkinEditor_Click"/>
                    <Button Grid.Column="1" x:Name="ToggleCapeEditorBtn" Classes="action" Content="🧥 Cape Maker" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="ToggleCapeEditor_Click"/>
                </Grid>
                
                <!-- Editor Area Container -->
                <Border x:Name="EditorContainer" IsVisible="False" Background="#08080C" CornerRadius="8" BorderBrush="#1A1A2E" BorderThickness="1" Padding="16">
                    <StackPanel Spacing="12">
                        <!-- Layer Selection (Skin only) -->
                        <Grid x:Name="EditorLayersRow" ColumnDefinitions="*,*">
                            <RadioButton x:Name="RadioBaseLayer" Content="Base Layer" IsChecked="True"/>
                            <RadioButton Grid.Column="1" x:Name="RadioOverlayLayer" Content="Overlay Layer"/>
                        </Grid>
                        
                        <!-- Skin Part selection -->
                        <ComboBox x:Name="SkinPartSelector" HorizontalAlignment="Stretch" Height="32" SelectedIndex="0">
                            <ComboBoxItem>Head (8x8)</ComboBoxItem>
                            <ComboBoxItem>Body (8x12)</ComboBoxItem>
                            <ComboBoxItem>Left Arm (4x12)</ComboBoxItem>
                            <ComboBoxItem>Right Arm (4x12)</ComboBoxItem>
                            <ComboBoxItem>Left Leg (4x12)</ComboBoxItem>
                            <ComboBoxItem>Right Leg (4x12)</ComboBoxItem>
                        </ComboBox>

                        <!-- Pixel Grid Canvas -->
                        <Border Background="#040406" BorderBrush="#1A1A2E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8" CornerRadius="4">
                            <Canvas x:Name="PixelEditorCanvas" Width="192" Height="192"/>
                        </Border>
                        
                        <!-- Color Picker / Palette / Sliders -->
                        <StackPanel Spacing="10">
                            <!-- Active Color & Hex Input -->
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="Brush Color" Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="ActiveColorPreview" Width="40" Height="28" CornerRadius="4" Background="White" BorderBrush="#1A1A2E" BorderThickness="1" Margin="8,0"/>
                                <TextBox Grid.Column="2" x:Name="ColorHexInput" Text="#FFFFFFFF" Width="90" Height="28" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                            </Grid>

                            <!-- Pre-made Palette -->
                            <WrapPanel x:Name="ColorPaletteContainer" ItemWidth="24" ItemHeight="24"/>

                            <!-- RGB Sliders -->
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                <!-- Red -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Foreground="#FF6666" FontSize="11" FontWeight="Bold" Width="15" VerticalAlignment="Center"/>
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="SliderRed" Minimum="0" Maximum="255" Value="255" TickFrequency="1" Margin="8,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TextRed" Text="255" Foreground="#888888" FontSize="11" Width="25" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                <!-- Green -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Foreground="#66FF66" FontSize="11" FontWeight="Bold" Width="15" VerticalAlignment="Center"/>
                                <Slider Grid.Row="1" Grid.Column="1" x:Name="SliderGreen" Minimum="0" Maximum="255" Value="255" TickFrequency="1" Margin="8,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TextGreen" Text="255" Foreground="#888888" FontSize="11" Width="25" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                <!-- Blue -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Foreground="#6666FF" FontSize="11" FontWeight="Bold" Width="15" VerticalAlignment="Center"/>
                                <Slider Grid.Row="2" Grid.Column="1" x:Name="SliderBlue" Minimum="0" Maximum="255" Value="255" TickFrequency="1" Margin="8,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TextBlue" Text="255" Foreground="#888888" FontSize="11" Width="25" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- Editor Actions -->
                        <Grid ColumnDefinitions="*,*">
                            <Button Classes="danger" Content="Clear Canvas" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="36" Click="ClearEditorCanvas_Click"/>
                            <Button Grid.Column="1" Classes="launch" Content="💾 Apply &amp; Save" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="36" Foreground="White" FontWeight="Bold" Click="SaveEditorDrawing_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
