{
  "schemaVersion": 1,
  "id": "theladscore",
  "version": "1.41.11",
  "name": "The Lads Core",
  "description": "Core mod for The Lads Client, integrating utility features.",
  "authors": [
    "The Lads"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/modid/icon.png",
  "environment": "*",
  "entrypoints": {
    "preLaunch": [
      "com.thelads.core.client.LadsEarlyWindow"
    ],
    "main": [
      "com.thelads.core.TheLadsCore"
    ],
    "client": [
      "com.thelads.core.client.TheLadsCoreClient",
      "com.thelads.core.features.signalloss.SignalLossClient",
      "xaero.lib.XaeroLibFabric",
      "xaero.minimap.XaeroMinimapFabric",
      "xaero.map.WorldMapFabric"
    ],
    "server": [
      "xaero.lib.XaeroLibFabric",
      "xaero.minimap.XaeroMinimapFabric",
      "xaero.map.WorldMapFabric"
    ],
    "modmenu": [
      "com.thelads.core.client.TheLadsModMenu"
    ],
    "sodium:config_api_user": [
      "com.thelads.core.client.renderscale.RenderScaleConfigEntryPoint"
    ],
    "jei_mod_plugin": [
      "mezz.jei.library.plugins.vanilla.VanillaPlugin",
      "mezz.jei.library.plugins.jei.JeiInternalPlugin",
      "mezz.jei.library.plugins.debug.JeiDebugPlugin",
      "mezz.jei.fabric.plugins.fabric.FabricGuiPlugin",
      "mezz.jei.gui.plugins.JeiGuiPlugin"
    ]
  },
  "mixins": [
    "theladscore.mixins.json",
    "theladscore.clientsort.mixins.json"
  ],
  "accessWidener": "scalablelux.accesswidener",
  "provides": [
    "xaerominimap",
    "xaeroworldmap",
    "scalablelux",
    "xaerolib",
    "serverpingerfixer",
    "raised",
    "quick-pack",
    "passiveshield",
    "immersive-hotbar",
    "screenfx",
    "fancy-door-anim",
    "threads",
    "waveycapes",
    "appleskin",
    "entity-view-distance",
    "notenoughanimations",
    "clienttweaks",
    "cursors_extended",
    "respackopts",
    "ixeris",
    "betterf1",
    "enhancedtooltips",
    "extremesoundmuffler",
    "jei"
  ],
  "depends": {
    "fabricloader": "\u003e\u003d0.19.2",
    "minecraft": "*",
    "java": "\u003e\u003d25",
    "fabric-api": "*"
