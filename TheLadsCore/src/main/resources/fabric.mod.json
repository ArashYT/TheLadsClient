{
	"schemaVersion": 1,
	"id": "theladscore",
	"version": "${version}",
	"name": "The Lads Core",
	"description": "Core mod for The Lads Client, integrating utility features.",
	"authors": [
		"The Lads"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/modid/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			"com.thelads.core.client.LadsEarlyWindow"
		],
		"main": [
			"com.thelads.core.TheLadsCore"
		],
		"client": [
			"com.thelads.core.client.TheLadsCoreClient",
			"xaero.lib.XaeroLibFabric",
			"xaero.minimap.XaeroMinimapFabric",
			"xaero.map.WorldMapFabric"
		],
		"server": [
			"xaero.lib.XaeroLibFabric",
			"xaero.minimap.XaeroMinimapFabric",
			"xaero.map.WorldMapFabric"
		],
		"modmenu": [
			"com.thelads.core.client.TheLadsModMenu"
		],
		"sodium:config_api_user": [
			"com.thelads.core.client.renderscale.RenderScaleConfigEntryPoint"
		],
		"jei_mod_plugin": [
			"mezz.jei.library.plugins.vanilla.VanillaPlugin",
			"mezz.jei.library.plugins.jei.JeiInternalPlugin",
			"mezz.jei.library.plugins.debug.JeiDebugPlugin",
			"mezz.jei.fabric.plugins.fabric.FabricGuiPlugin",
			"mezz.jei.gui.plugins.JeiGuiPlugin"
		]
	},
	"mixins": [
		"theladscore.mixins.json",
		"theladscore.clientsort.mixins.json",
		"xaerolib.mixins.json",
		"xaerolib.fabric.mixins.json",
		"xaerohud.mixins.json",
		"xaerohud.fabric.mixins.json",
		"xaerominimap.mixins.json",
		"xaerominimap.fabric.mixins.json",
		"xaeroworldmap.mixins.json",
		"xaeroworldmap.fabric.mixins.json",
		"scalablelux.mixins.json",
		"serverpingerfixer.mixins.json",
		"raised.mixins.json",
		"quick-pack.mixins.json",
		"immersive-hotbar.mixins.json",
		{"config": "immersive-hotbar.client.mixins.json", "environment": "client"},
		{"config": "screenfx.mixins.json", "environment": "client"},
		"fancy-door-anim.client.mixins.json",
		"waveycapes.mixins.json",
		"appleskin.mixins.json",
		{"config": "appleskin.jei.mixins.json", "environment": "client"},
		"entityviewdistance.mixins.json",
		"notenoughanimations.mixins.json",
		"clienttweaks.mixins.json",
		"clienttweaks.fabric.mixins.json",
		{"config": "cursors_extended.mixins.json", "environment": "client"},
		{"config": "cursors_extended.fabric.mixins.json", "environment": "client"},
		"respackopts.mixins.json",
		{"config": "respackopts.client.mixins.json", "environment": "client"},
		{"config": "ixeris.mixins.json", "environment": "client"},
		{"config": "ixeris.core.mixins.json", "environment": "client"},
		"betterf1.mixins.json",
		"enhancedtooltips.mixins.json",
		"extremesoundmuffler.mixins.json",
		"jei.mixins.json"
	],
	"accessWidener": "scalablelux.accesswidener",
	"provides": [
		"xaerominimap",
		"xaeroworldmap",
		"scalablelux",
		"xaerolib",
		"serverpingerfixer",
		"raised",
		"quick-pack",
		"passiveshield",
		"immersive-hotbar",
		"screenfx",
		"fancy-door-anim",
		"threads",
		"waveycapes",
		"appleskin",
		"entity-view-distance",
		"notenoughanimations",
		"clienttweaks",
		"cursors_extended",
		"respackopts",
		"ixeris",
		"betterf1",
		"enhancedtooltips",
		"extremesoundmuffler",
		"jei"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "*",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
